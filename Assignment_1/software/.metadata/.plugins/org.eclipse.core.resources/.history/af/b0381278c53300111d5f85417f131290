
#include <stdio.h>
#include <unistd.h>

#include "system.h"
#include "sys/alt_irq.h"
#include "io.h"
#include "altera_avalon_pio_regs.h"

#include "freertos/FreeRTOS.h"
#include "FreeRTOS/queue.h"
#include "FreeRTOS/task.h"
#include "FreeRTOS/timers.h"

// Definition of Task Stacks
#define   TASK_STACKSIZE       2048


// Definition of Task priorities
#define FREQ_ANALYSER_PRIORITY 12

// Defining ADC_QUEUE
#define ADC_QUEUE_SIZE sizeof( uint32_t)
QueueHandle_t ADC_queue;

// Local function prototypes
int initCreateTasks(void);
int initOSDataStructs(void);

// FREQUENCY ANALYSER TASK
void freqAnalyser(void *pvParameters){
	unsigned int adc_count;

	adc_count = IORD(FREQUENCY_ANALYSER_BASE, 0);
	printf("%f Hz\n", 16000/(double)adc_count);
	return;

}

//Create the queue
int initOSDataStructs(void)
{
	ADC_queue = xQueueCreate( ADC_QUEUE_SIZE, sizeof(unsigned int) );
	return 0;
}

int initCreateTask(void){
	xTaskCreate( freqAnalyser, "freq_analyser", TASK_STACKSIZE, NULL, FREQ_ANALYSER_PRIORITY, NULL );
	return 0;
}

int main(){
	initOSDataStructs();
	initCreateTask();

	alt_irq_register(FREQUENCY_ANALYSER_IRQ, 0, freqAnalyser);
}

