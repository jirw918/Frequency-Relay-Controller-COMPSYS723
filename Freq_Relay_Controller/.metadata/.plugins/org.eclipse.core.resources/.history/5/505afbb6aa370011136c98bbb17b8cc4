// Definition of Task Stacks
#define   TASK_STACKSIZE       2048

//global variable definition
volatile int systemState = 0;
volatile int buttonValue = 0;
volatile unsigned  int uiSwitchValue = 0;
volatile int loadState;

//global variable semaphores
SemaphoreHandle_t systemStateSem = NULL;


void vInitSemaphores() {
	systemStateSem = xSemaphoreCreateBinary();
	    if (systemStateSem != NULL) {
	        xSemaphoreGive(systemStateSem);
	    }
}

/* Interrupt defines */
void button_interrupts_function(void* context, alt_u32 id)
{
  // need to cast the context first before using it
  int* temp = (int*) context;
  (*temp) = IORD_ALTERA_AVALON_PIO_EDGE_CAP(PUSH_BUTTON_BASE);

  // clears the edge capture register
  IOWR_ALTERA_AVALON_PIO_EDGE_CAP(PUSH_BUTTON_BASE, 0x7);


  BaseType_t xHigherPriorityTaskWoken = pdFALSE;
  xSemaphoreGiveFromISR(systemStateSem, &xHigherPriorityTaskWoken);
  portEND_SWITCHING_ISR(xHigherPriorityTaskWoken);
}


void ps2_isr(void* ps2_device, alt_u32 id){
	unsigned char byte;
	alt_up_ps2_read_data_byte_timeout(ps2_device, &byte);
	printf("Scan code: %x\n", byte);
}

//init interrupts


void vSwitchPoll(){
	while(1){
		if(systemState == 1){
			if(IORD_ALTERA_AVALON_PIO_DATA(SLIDE_SWITCH_BASE) < uiSwitchValue){
				uiSwitchValue = IORD_ALTERA_AVALON_PIO_DATA(SLIDE_SWITCH_BASE);
			}
		} else {
		uiSwitchValue = IORD_ALTERA_AVALON_PIO_DATA(SLIDE_SWITCH_BASE);
		}

		printf("%d\n", uiSwitchValue);
		printf("butoon %d\n", buttonValue);
		vTaskDelay(200);
	}
}

void vPrintAlive(){
