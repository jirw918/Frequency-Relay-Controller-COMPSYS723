void vCheckButtonTask(){

	while(1){

		// Triggered by the button
		xSemaphoreTake(buttonSem, portMAX_DELAY);

		xSemaphoreTake(stateMutex, portMAX_DELAY);
		if(systemState == 0){
			systemState = 2;
		}
		else if(systemState == 2){
			systemState = 0;
		}

		xSemaphoreGive(stateMutex);
	}
}


