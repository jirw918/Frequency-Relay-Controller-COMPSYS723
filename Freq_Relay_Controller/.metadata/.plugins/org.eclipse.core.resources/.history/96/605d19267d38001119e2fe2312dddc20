}
void vLoadControlTask(){
	while(1){

		//check system state based on frequency
		//swithc into mananging here if needed.



		switch(systemState){
			case 0:
				//System in normal, the swithces control the loads.
				loadState = uiSwitchValue;
				IOWR_ALTERA_AVALON_PIO_DATA(RED_LEDS_BASE, loadState);
				break;
			case 1:
				//Managing where Relay sheds the loads, swtiches can only turn off the loads.
				if(uiSwitchValue < loadState){
					loadState = uiSwitchValue;
				}

				//shed loads based on stability.
				//compare freq to target freq.
				//if freq drops below target freq restart timer
				//if freq doesnt drop below in windows then reconnect load.



				IOWR_ALTERA_AVALON_PIO_DATA(RED_LEDS_BASE, loadState);
				break;
			case 2:
				//Maintanence where only the switches control the loads, and
				loadState = uiSwitchValue;
				IOWR_ALTERA_AVALON_PIO_DATA(RED_LEDS_BASE, loadState);
				break;
			}

		vTaskDelay(100);
	}
}

