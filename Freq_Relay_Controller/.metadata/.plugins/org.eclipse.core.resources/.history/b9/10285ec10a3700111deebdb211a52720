/* Standard includes. */
#include <stddef.h>
#include <stdio.h>
#include <string.h>

/* Scheduler includes. */
#include "freertos/FreeRTOS.h"
#include "freertos/task.h"
#include "freertos/queue.h"
#include "freertos/semphr.h"

//Altera includes
#include "altera_avalon_pio_regs.h"
#include "alt_types.h"                 	// alt_u32 is a kind of alt_types
#include "sys/alt_irq.h"              	// to register interrupts

// Definition of Task Stacks
#define   TASK_STACKSIZE       2048

//global variable definition
volatile uint8_t systemState = 0;
volatile int buttonValue = 0;

//global variable semaphores
SemaphoreHandle_t systemStateSem = xSemaphoreCreateBinary();


void vInitSemaphores() {
	xSemaphoreGive(systemStateSem);
}

/* Interrupt defines */
void button_interrupts_function(void* context, alt_u32 id)
{
  // need to cast the context first before using it
  int* temp = (int*) context;
  (*temp) = IORD_ALTERA_AVALON_PIO_EDGE_CAP(PUSH_BUTTON_BASE);

  // clears the edge capture register
  IOWR_ALTERA_AVALON_PIO_EDGE_CAP(PUSH_BUTTON_BASE, 0x7);
}

//init interrupts


void vSwitchPoll(){
	unsigned  int uiSwitchValue = 0;
	while(1){
		uiSwitchValue = IORD_ALTERA_AVALON_PIO_DATA(SLIDE_SWITCH_BASE);

		printf("%d\n", uiSwitchValue);
		printf("butoon %d\n", buttonValue);
		vTaskDelay(500);
	}
}

void vPrintAlive(){
	while(1){
		printf("da dump\n");
		vTaskDelay(1000);
	}

}

void vCheckButtonTask(){

	while(1){
		if(buttonValue == 1){
				xSemaphoreTake(systemStateSem, portMAX_DELAY);
				if(systemState == 2){
					systemState = 0;
				} else {
					systemState = 2;
				}
			}	xSemaphoreGive(systemStateSem);

			vTaskDelay(1500);
	}
}

int main(void)
{
	printf("Hello\n");

	vInitSemaphores();

	  // clears the edge capture register. Writing 1 to bit clears pending interrupt for corresponding button.
	  IOWR_ALTERA_AVALON_PIO_EDGE_CAP(PUSH_BUTTON_BASE, 0x7);

	  // enable interrupts for all buttons
	  IOWR_ALTERA_AVALON_PIO_IRQ_MASK(PUSH_BUTTON_BASE, 0x7);

	  // register the ISR
	  alt_irq_register(PUSH_BUTTON_IRQ,(void*)&buttonValue, button_interrupts_function);

	//Create Tasks
	xTaskCreate(vCheckButtonTask, "check button", TASK_STACKSIZE, NULL, 1, NULL);
	xTaskCreate(vSwitchPoll, "keypoll", TASK_STACKSIZE, NULL, 1, NULL);
	xTaskCreate(vPrintAlive, "Alive", TASK_STACKSIZE, NULL, 1, NULL);

	/* Finally start the scheduler. */
	vTaskStartScheduler();

	/* Will only reach here if there is insufficient heap available to start
	 the scheduler. */
	for (;;);
}


