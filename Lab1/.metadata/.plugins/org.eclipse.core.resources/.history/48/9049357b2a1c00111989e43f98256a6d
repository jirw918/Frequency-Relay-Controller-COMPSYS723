/* Standard includes. */
#include <stddef.h>
#include <stdio.h>
#include <string.h>

/* Scheduler includes. */
#include "freertos/FreeRTOS.h"
#include "freertos/task.h"
#include "freertos/queue.h"
#include "freertos/semphr.h"

#include <altera_avalon_pio_regs.h>

// Definition of Task Stacks
#define   TASK_STACKSIZE       2048

/* The parameters passed to the reg test tasks.  This is just done to check
 the parameter passing mechanism is working correctly. */
#define mainREG_TEST_1_PARAMETER    ( ( void * ) 0x12345678 )
#define mainREG_TEST_2_PARAMETER    ( ( void * ) 0x87654321 )
#define mainREG_TEST_PRIORITY       ( tskIDLE_PRIORITY + 1)


#define lcd_task1_priority 13
#define lcd_task2_priority 14

//defines for driving LCD
#define ESC 27
#define CLEAR_LCD_STRING "[2J"

FILE *lcd;

xSemaphoreHandle shared_lcd_sem;
shared_lcd_sem = xSemaphoreCreateCounting( 9999, 1 );

/*
 * Create the demo tasks then start the scheduler.
 */

void counter_task(void *pvParameters){

	int counter = 0;

	while(1)
	{
		counter++;

		if (counter == 10){
			counter = 0;
		}

		// write a value to the seven-segment display
		IOWR_ALTERA_AVALON_PIO_DATA(SEVEN_SEG_BASE, counter);

		// make the task delay for 1 second
		vTaskDelay(1000);
	}
}

void lcd_task1(void* pvParameters)
{
	while(1){
		// insert some code here to request semaphore
		xSemaphoreTake(shared_lcd_sem, portMAX_DELAY);
		// clear the LCD
		fprintf(lcd, "%c%s", ESC, CLEAR_LCD_STRING);
		fprintf(lcd, "LCD task 1\n");
		// insert some code here to release semaphore
		xSemaphoreGive(shared_lcd_sem);
		// insert the time delay
		vTaskDelay(5000);
	}
}

void lcd_task2(void* pvParameters)
{
	while(1)
	{
		// insert some code here to request semaphore
		xSemaphoreTake(shared_lcd_sem, portMAX_DELAY);
		// clear the LCD
		fprintf(lcd, "%c%s", ESC, CLEAR_LCD_STRING);
		fprintf(lcd, "\nLCD task 2\n");
		// insert some code here to release semaphore
		xSemaphoreGive(shared_lcd_sem);
		// insert the time delay
		vTaskDelay(3000);
	}
}



int main(void)
{

	FILE *lcd;
	lcd = fopen(CHARACTER_LCD_NAME, "w");
	// clear lcd
	fprintf(lcd, "%c%s", ESC, CLEAR_LCD_STRING);

	xTaskCreate(counter_task, "counter_task", TASK_STACKSIZE, NULL, 1, NULL);
	xTaskCreate(lcd_task1,"lcd_task1",TASK_STACKSIZE,NULL,lcd_task1_priority,NULL);
	xTaskCreate (lcd_task2,"lcd_task2",TASK_STACKSIZE,NULL,lcd_task2_priority,NULL);


	/* Finally start the scheduler. */
	vTaskStartScheduler();

	/* Will only reach here if there is insufficient heap available to start
	 the scheduler. */
	for (;;);

	//Close the LCD file discriptor.
	fclose(lcd);
}




